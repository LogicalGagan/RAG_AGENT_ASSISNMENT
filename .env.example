APP_ENV=development
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Optional: enables richer image understanding, audio transcription, embeddings, and final response generation.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

CHUNK_SIZE=900
CHUNK_OVERLAP=150
QUERY_TOP_K=5
GRAPH_NEIGHBOR_LIMIT=3
