APP_ENV=development
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Default local Ollama path for reliable demos.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2:0.5b
OLLAMA_VISION_MODEL=moondream
OLLAMA_TIMEOUT_SECONDS=120

# Optional OpenAI path if you want cloud generation / cloud vision instead.
# Leave these blank for the default fully local Ollama-based setup.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

CHUNK_SIZE=900
CHUNK_OVERLAP=150
QUERY_TOP_K=5
GRAPH_NEIGHBOR_LIMIT=3
